.ie \n(.g .ds Aq \(aq
.el .ds Aq '
.TH tapectl-db 1  "tapectl-db " 
.SH NAME
tapectl\-db \- Database operations
.SH SYNOPSIS
\fBtapectl db\fR [\fB\-\-json\fR] [\fB\-\-dry\-run\fR] [\fB\-v\fR|\fB\-\-verbose\fR] [\fB\-y\fR|\fB\-\-yes\fR] [\fB\-\-config\fR] [\fB\-h\fR|\fB\-\-help\fR] <\fIsubcommands\fR>
.SH DESCRIPTION
Database operations
.SH OPTIONS
.TP
\fB\-\-json\fR
Output in JSON format
.TP
\fB\-\-dry\-run\fR
Show what would be done without making changes
.TP
\fB\-v\fR, \fB\-\-verbose\fR
Enable verbose output
.TP
\fB\-y\fR, \fB\-\-yes\fR
Skip confirmation prompts
.TP
\fB\-\-config\fR \fI<CONFIG>\fR
Path to config file
.TP
\fB\-h\fR, \fB\-\-help\fR
Print help
.SH SUBCOMMANDS
.TP
tapectl\-db\-backup(1)
Backup database, keys, and catalogs
.TP
tapectl\-db\-fsck(1)
Check database integrity
.TP
tapectl\-db\-export(1)
Export database as JSON
.TP
tapectl\-db\-import(1)
Import database from backup
.TP
tapectl\-db\-stats(1)
Show database statistics
.TP
tapectl\-db\-help(1)
Print this message or the help of the given subcommand(s)
