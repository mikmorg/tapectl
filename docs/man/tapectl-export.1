.el .ds Aq '
.TH tapectl-export 1  "tapectl-export " 
.SH NAME
tapectl\-export \- Export encrypted slices to directory
.SH SYNOPSIS
\fBtapectl export\fR [\fB\-\-json\fR] <\fB\-\-unit\fR> [\fB\-\-dry\-run\fR] <\fB\-\-to\fR> [\fB\-v\fR|\fB\-\-verbose\fR] [\fB\-y\fR|\fB\-\-yes\fR] [\fB\-\-config\fR] [\fB\-h\fR|\fB\-\-help\fR] 
.SH DESCRIPTION
Export encrypted slices to directory
.SH OPTIONS
.TP
\fB\-\-json\fR
Output in JSON format
.TP
\fB\-\-unit\fR \fI<UNIT>\fR
Unit name
.TP
\fB\-\-dry\-run\fR
Show what would be done without making changes
.TP
\fB\-\-to\fR \fI<TO>\fR
Destination directory
.TP
\fB\-v\fR, \fB\-\-verbose\fR
Enable verbose output
.TP
\fB\-y\fR, \fB\-\-yes\fR
Skip confirmation prompts
.TP
\fB\-\-config\fR \fI<CONFIG>\fR
Path to config file
.TP
\fB\-h\fR, \fB\-\-help\fR
Print help
